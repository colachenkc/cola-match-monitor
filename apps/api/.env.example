# Copy to .env and customize for local development.
# For production (Fly.io) set these via `fly secrets set` or fly.toml [env]
# — do NOT commit real secrets to git.

# DATABASE_URL=sqlite:///./match_monitor.db
# CORS_ORIGINS=["http://localhost:3000"]
# UPLOAD_ROOT=uploads

# Admin authentication — REQUIRED in production
ADMIN_PASSWORD=changeme
# Generate a random 32+ char string, e.g. `python -c "import secrets;print(secrets.token_urlsafe(32))"`
SESSION_SECRET=dev-secret-change-me

# Cookie options.
# Local dev (HTTP, same-origin): COOKIE_SECURE=false, COOKIE_SAMESITE=lax
# Production (HTTPS, cross-origin Vercel → Fly): COOKIE_SECURE=true, COOKIE_SAMESITE=none
# COOKIE_SECURE=false
# COOKIE_SAMESITE=lax
